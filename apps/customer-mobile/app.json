{
  "expo": {
    "name": "JanLums",
    "slug": "janlums-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "janlums",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0078D4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.janlums.customer",
      "infoPlist": {
        "NSCameraUsageDescription": "JanLums needs camera access to scan QR codes for order pickup.",
        "NSPhotoLibraryUsageDescription": "JanLums needs photo library access to upload garment photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0078D4"
      },
      "package": "com.janlums.customer",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "JanLums needs camera access to scan QR codes for order pickup."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "env": "development",
      "apiUrl": "http://10.0.2.2:3015/api/v1",
      "appName": "JanLums",
      "tenantId": "30960b5f-ebb1-44e6-8a87-f6b441ec18ac",
      "sentryDsn": "",
      "posthogKey": "",
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
